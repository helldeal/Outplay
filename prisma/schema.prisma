generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

model User {
  id              String   @id @db.Uuid
  createdAt       DateTime @default(now())
  username        String?
  avatarUrl       String?  @map("avatar_url")
  pcBalance       Int      @default(0) @map("pc_balance")
  totalPcEarned   BigInt   @default(0) @map("total_pc_earned")
  title           String?
  signatureCardId String?  @map("signature_card_id")

  signatureCard Card? @relation("UserSignatureCard", fields: [signatureCardId], references: [id])

  userCards       UserCard[]
  boosterOpenings BoosterOpening[]
  loginStreak     LoginStreak?
  achievements    UserAchievement[]

  @@map("users")
  @@schema("public")
}

model Game {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  logoUrl   String
  createdAt DateTime @default(now())
  cards     Card[]

  @@map("games")
  @@schema("public")
}

model Team {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  logoUrl   String
  createdAt DateTime @default(now())

  cards Card[]

  @@map("teams")
  @@schema("public")
}

model Nationality {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  code      String   @unique
  flagUrl   String
  createdAt DateTime @default(now())

  cards Card[]

  @@map("nationalities")
  @@schema("public")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  iconUrl   String
  createdAt DateTime @default(now())

  cards Card[]

  @@map("roles")
  @@schema("public")
}

model Series {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  slug       String   @unique
  code       String   @unique
  coverImage String
  createdAt  DateTime @default(now())

  cards           Card[]
  boosters        Booster[]
  boosterOpenings BoosterOpening[]

  @@map("series")
  @@schema("public")
}

model Card {
  id           String  @id // S1-01, S1-70
  name         String
  rarity       Rarity
  pcValue      Int     @default(0) @map("pc_value")
  imageUrl     String
  animationUrl String?

  seriesId String @map("series_id") @db.Uuid
  series   Series @relation(fields: [seriesId], references: [id])

  gameId String @map("game_id") @db.Uuid
  game   Game   @relation(fields: [gameId], references: [id])

  teamId String? @map("team_id") @db.Uuid
  team   Team?   @relation(fields: [teamId], references: [id])

  nationalityId String      @map("nationality_id") @db.Uuid
  nationality   Nationality @relation(fields: [nationalityId], references: [id])

  roleId String? @map("role_id") @db.Uuid
  role   Role?   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  userCards      UserCard[]
  signatureUsers User[]     @relation("UserSignatureCard")

  @@index([seriesId])
  @@index([rarity])
  @@map("cards")
  @@schema("public")
}

model Booster {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  type        BoosterType
  pricePc     Int         @default(0) @map("price_pc")
  imageUrl    String?     @map("image_url")
  isDailyOnly Boolean     @default(false) @map("is_daily_only")
  dropRates   Json        @map("drop_rates")

  seriesId String @map("series_id") @db.Uuid
  series   Series @relation(fields: [seriesId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  boosterOpenings BoosterOpening[]

  @@unique([seriesId, type])
  @@map("boosters")
  @@schema("public")
}

model UserCard {
  userId     String   @map("user_id") @db.Uuid
  cardId     String   @map("card_id")
  obtainedAt DateTime @default(now()) @map("obtained_at")

  user User @relation(fields: [userId], references: [id])
  card Card @relation(fields: [cardId], references: [id])

  @@id([userId, cardId])
  @@index([userId])
  @@map("user_cards")
  @@schema("public")
}

model BoosterOpening {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  boosterId      String      @map("booster_id") @db.Uuid
  seriesId       String      @map("series_id") @db.Uuid
  cards          Json
  pcGained       Int         @default(0) @map("pc_gained")
  duplicateCards Int         @default(0) @map("duplicate_cards")
  type           OpeningType @default(SHOP)
  createdAt      DateTime    @default(now()) @map("created_at")

  user                 User              @relation(fields: [userId], references: [id])
  booster              Booster           @relation(fields: [boosterId], references: [id])
  series               Series            @relation(fields: [seriesId], references: [id])
  rewardedAchievements UserAchievement[]

  @@index([userId])
  @@map("booster_openings")
  @@schema("public")
}

model LoginStreak {
  userId           String    @id @map("user_id") @db.Uuid
  currentDay       Int       @default(0) @map("current_day")
  lastClaimDate    DateTime? @map("last_claim_date") @db.Date
  totalClaimedDays Int       @default(0) @map("total_claimed_days")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_streaks")
  @@schema("public")
}

model AchievementDefinition {
  id                String       @id @default(uuid()) @db.Uuid
  code              String       @unique
  name              String
  category          String
  description       String
  metricKey         String       @map("metric_key")
  targetValue       Decimal      @map("target_value") @db.Decimal
  rewardPc          Int          @default(0) @map("reward_pc")
  rewardBoosterType BoosterType? @map("reward_booster_type")
  rewardTitle       String?      @map("reward_title")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  userAchievements UserAchievement[]

  @@map("achievement_definitions")
  @@schema("public")
}

model UserAchievement {
  userId          String    @map("user_id") @db.Uuid
  achievementId   String    @map("achievement_id") @db.Uuid
  unlockedAt      DateTime  @default(now()) @map("unlocked_at") @db.Timestamptz(6)
  rewardGrantedAt DateTime? @map("reward_granted_at") @db.Timestamptz(6)
  notifiedAt      DateTime? @map("notified_at") @db.Timestamptz(6)
  seenAt          DateTime? @map("seen_at") @db.Timestamptz(6)
  rewardOpeningId String?   @map("reward_opening_id") @db.Uuid

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  rewardOpening BoosterOpening?       @relation(fields: [rewardOpeningId], references: [id], onDelete: SetNull)

  @@id([userId, achievementId])
  @@index([userId, unlockedAt])
  @@map("user_achievements")
  @@schema("public")
}

enum Rarity {
  ROOKIE
  CHALLENGER
  CHAMPION
  WORLD_CLASS
  LEGENDS

  @@schema("public")
}

enum BoosterType {
  NORMAL
  LUCK
  PREMIUM
  GODPACK

  @@schema("public")
}

enum OpeningType {
  SHOP
  DAILY
  STREAK
  ACHIEVEMENT

  @@schema("public")
}
